# SOQ-TEC Relayer Environment Configuration
# Copy to .env and fill in values

# ── Network ──────────────────────────────
NETWORK=devnet

# ── Solana ───────────────────────────────
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=SoQTECBridgeProgram11111111111111111111111
PSOQ_MINT=

# ── Soqucoin ────────────────────────────
SOQUCOIN_RPC=http://localhost:44555
SOQUCOIN_RPC_USER=
SOQUCOIN_RPC_PASS=
VAULT_ADDRESS=

# ── Validators ──────────────────────────
THRESHOLD=3
VALIDATOR_COUNT=5
VALIDATOR_KEY_PATH=./keys

# ── API Server ──────────────────────────
API_PORT=3001
CORS_ORIGINS=https://soqtec.soqu.org,http://localhost:3000

# ── Transfer Limits (SOQ) ───────────────
DAILY_LIMIT=1000000
MIN_TRANSFER=100
MAX_TRANSFER=100000

# ── Polling Intervals (ms) ──────────────
SOLANA_POLL_MS=2000
SOQUCOIN_POLL_MS=10000

# ── Logging ─────────────────────────────
LOG_LEVEL=info
